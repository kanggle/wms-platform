{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wms.example.com/contracts/http/zone-response.v1.json",
  "title": "Zone resource response",
  "description": "Derived from specs/contracts/http/master-service-api.md §2 Zone.",
  "type": "object",
  "required": [
    "id",
    "warehouseId",
    "zoneCode",
    "name",
    "zoneType",
    "status",
    "version",
    "createdAt",
    "createdBy",
    "updatedAt",
    "updatedBy"
  ],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string" },
    "warehouseId": { "type": "string" },
    "zoneCode": { "type": "string", "pattern": "^Z-[A-Z0-9]+$" },
    "name": { "type": "string", "minLength": 1, "maxLength": 100 },
    "zoneType": {
      "type": "string",
      "enum": ["AMBIENT", "CHILLED", "FROZEN", "RETURNS", "BULK", "PICK"]
    },
    "status": { "type": "string", "enum": ["ACTIVE", "INACTIVE"] },
    "version": { "type": "integer", "minimum": 0 },
    "createdAt": { "type": "string" },
    "createdBy": { "type": "string" },
    "updatedAt": { "type": "string" },
    "updatedBy": { "type": "string" }
  }
}
