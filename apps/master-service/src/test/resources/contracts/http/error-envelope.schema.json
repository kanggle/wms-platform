{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wms.example.com/contracts/http/error-envelope.v1.json",
  "title": "API error envelope",
  "description": "Derived from specs/contracts/http/master-service-api.md § Error Envelope and platform/error-handling.md. Used for all 4xx/5xx responses.",
  "type": "object",
  "required": ["error"],
  "additionalProperties": false,
  "properties": {
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": true,
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "details": { "type": ["object", "null"] },
        "traceId": { "type": ["string", "null"] },
        "requestId": { "type": ["string", "null"] }
      }
    }
  }
}
