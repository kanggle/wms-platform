{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wms.example.com/contracts/http/location-response.v1.json",
  "title": "Location resource response",
  "description": "Derived from specs/contracts/http/master-service-api.md §3 Location.",
  "type": "object",
  "required": [
    "id",
    "warehouseId",
    "zoneId",
    "locationCode",
    "locationType",
    "status",
    "version",
    "createdAt",
    "createdBy",
    "updatedAt",
    "updatedBy"
  ],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string" },
    "warehouseId": { "type": "string" },
    "zoneId": { "type": "string" },
    "locationCode": { "type": "string", "pattern": "^WH\\d{2,3}-[A-Z0-9]+(-[A-Z0-9]+){1,5}$" },
    "aisle": { "type": ["string", "null"] },
    "rack": { "type": ["string", "null"] },
    "level": { "type": ["string", "null"] },
    "bin": { "type": ["string", "null"] },
    "locationType": {
      "type": "string",
      "enum": ["STORAGE", "STAGING_INBOUND", "STAGING_OUTBOUND", "DAMAGED", "QUARANTINE"]
    },
    "capacityUnits": { "type": ["integer", "null"], "minimum": 1 },
    "status": { "type": "string", "enum": ["ACTIVE", "INACTIVE"] },
    "version": { "type": "integer", "minimum": 0 },
    "createdAt": { "type": "string" },
    "createdBy": { "type": "string" },
    "updatedAt": { "type": "string" },
    "updatedBy": { "type": "string" }
  }
}
