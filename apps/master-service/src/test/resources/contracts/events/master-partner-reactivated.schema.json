{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wms.example.com/contracts/events/master-partner-reactivated.v1.json",
  "title": "master.partner.reactivated event envelope",
  "description": "Derived from specs/contracts/events/master-events.md §5. Snapshot has status=ACTIVE.",
  "type": "object",
  "required": [
    "eventId", "eventType", "eventVersion", "occurredAt", "producer",
    "aggregateType", "aggregateId", "actorId", "payload"
  ],
  "additionalProperties": false,
  "properties": {
    "eventId": { "type": "string" },
    "eventType": { "type": "string", "const": "master.partner.reactivated" },
    "eventVersion": { "type": "integer", "minimum": 1 },
    "occurredAt": { "type": "string" },
    "producer": { "type": "string", "const": "master-service" },
    "aggregateType": { "type": "string", "const": "partner" },
    "aggregateId": { "type": "string" },
    "traceId": { "type": ["string", "null"] },
    "actorId": { "type": ["string", "null"] },
    "payload": {
      "type": "object",
      "required": ["partner"],
      "additionalProperties": false,
      "properties": {
        "partner": { "$ref": "#/$defs/partnerSnapshot" }
      }
    }
  },
  "$defs": {
    "partnerSnapshot": {
      "type": "object",
      "required": ["id", "partnerCode", "name", "partnerType", "status",
        "version", "createdAt", "createdBy", "updatedAt", "updatedBy"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "partnerCode": { "type": "string" },
        "name": { "type": "string" },
        "partnerType": { "type": "string", "enum": ["SUPPLIER", "CUSTOMER", "BOTH"] },
        "businessNumber": { "type": ["string", "null"] },
        "contactName": { "type": ["string", "null"] },
        "contactEmail": { "type": ["string", "null"] },
        "contactPhone": { "type": ["string", "null"] },
        "address": { "type": ["string", "null"] },
        "status": { "type": "string", "enum": ["ACTIVE", "INACTIVE"] },
        "version": { "type": "integer", "minimum": 0 },
        "createdAt": { "type": "string" },
        "createdBy": { "type": "string" },
        "updatedAt": { "type": "string" },
        "updatedBy": { "type": "string" }
      }
    }
  }
}
