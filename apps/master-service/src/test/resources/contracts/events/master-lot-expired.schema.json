{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wms.example.com/contracts/events/master-lot-expired.v1.json",
  "title": "master.lot.expired event envelope",
  "description": "System-originated event emitted by the daily lot-expiration scheduler. actorId is always null; triggeredBy identifies the job.",
  "type": "object",
  "required": [
    "eventId", "eventType", "eventVersion", "occurredAt", "producer",
    "aggregateType", "aggregateId", "actorId", "payload"
  ],
  "additionalProperties": false,
  "properties": {
    "eventId": { "type": "string" },
    "eventType": { "type": "string", "const": "master.lot.expired" },
    "eventVersion": { "type": "integer", "minimum": 1 },
    "occurredAt": { "type": "string" },
    "producer": { "type": "string", "const": "master-service" },
    "aggregateType": { "type": "string", "const": "lot" },
    "aggregateId": { "type": "string" },
    "traceId": { "type": ["string", "null"] },
    "actorId": { "type": "null" },
    "payload": {
      "type": "object",
      "required": ["lot", "triggeredBy", "scheduledAt"],
      "additionalProperties": false,
      "properties": {
        "lot": { "$ref": "#/$defs/lotSnapshot" },
        "triggeredBy": { "type": "string", "const": "scheduled-job:lot-expiry" },
        "scheduledAt": { "type": "string" }
      }
    }
  },
  "$defs": {
    "lotSnapshot": {
      "type": "object",
      "required": ["id", "skuId", "lotNo", "status", "version",
        "createdAt", "createdBy", "updatedAt", "updatedBy"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "skuId": { "type": "string" },
        "lotNo": { "type": "string" },
        "manufacturedDate": { "type": ["string", "null"] },
        "expiryDate": { "type": ["string", "null"] },
        "supplierPartnerId": { "type": ["string", "null"] },
        "status": { "type": "string", "const": "EXPIRED" },
        "version": { "type": "integer" },
        "createdAt": { "type": "string" },
        "createdBy": { "type": "string" },
        "updatedAt": { "type": "string" },
        "updatedBy": { "type": "string" }
      }
    }
  }
}
