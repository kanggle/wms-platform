{
  "uid": "gateway-overview",
  "title": "Gateway Service Overview",
  "tags": ["gateway"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    { "id": 1, "title": "Request Rate (req/s)", "type": "timeseries", "gridPos": { "h": 6, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "sum(rate(http_server_requests_seconds_count{service=\"gateway-service\"}[5m]))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    { "id": 2, "title": "Latency p50", "type": "timeseries", "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{service=\"gateway-service\"}[5m])) by (le))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    { "id": 3, "title": "Latency p99", "type": "timeseries", "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{service=\"gateway-service\"}[5m])) by (le))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    { "id": 4, "title": "JWT Validation Failures", "type": "timeseries", "gridPos": { "h": 6, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "rate(gateway_jwt_validation_total{result=\"failure\"}[5m])", "refId": "A" }]
    },
    { "id": 5, "title": "Rate Limit 429", "type": "timeseries", "gridPos": { "h": 6, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "rate(gateway_ratelimit_rejected_total[5m])", "refId": "A" }]
    },
    { "id": 6, "title": "JWKS Cache Hit Rate", "type": "timeseries", "gridPos": { "h": 6, "w": 8, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "rate(gateway_jwks_cache_hits_total[5m]) / (rate(gateway_jwks_cache_hits_total[5m]) + rate(gateway_jwks_cache_misses_total[5m]))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    { "id": 7, "title": "Upstream 5xx", "type": "timeseries", "gridPos": { "h": 6, "w": 8, "x": 8, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "sum(rate(http_server_requests_seconds_count{service=\"gateway-service\",status=~\"5..\"}[5m])) by (uri)", "legendFormat": "{{uri}}", "refId": "A" }]
    },
    { "id": 8, "title": "Status Code Breakdown", "type": "timeseries", "gridPos": { "h": 6, "w": 8, "x": 16, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "sum(rate(http_server_requests_seconds_count{service=\"gateway-service\"}[5m])) by (status)", "legendFormat": "{{status}}", "refId": "A" }]
    }
  ]
}
