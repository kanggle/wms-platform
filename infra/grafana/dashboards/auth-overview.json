{
  "uid": "auth-overview",
  "title": "Auth Service Overview",
  "tags": ["auth"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    { "id": 1, "title": "Login Success Rate", "type": "timeseries", "gridPos": { "h": 6, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "rate(auth_login_total{result=\"success\"}[5m])", "refId": "A" }]
    },
    { "id": 2, "title": "Login Failure Rate", "type": "timeseries", "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "rate(auth_login_total{result=\"failure\"}[5m])", "refId": "A" }]
    },
    { "id": 3, "title": "Login Latency p99", "type": "timeseries", "gridPos": { "h": 6, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{service=\"auth-service\",uri=\"/api/auth/login\"}[5m])) by (le))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    { "id": 4, "title": "Refresh Token Rotation", "type": "timeseries", "gridPos": { "h": 6, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "sum(rate(auth_token_refresh_total[5m])) by (result)", "legendFormat": "{{result}}", "refId": "A" }]
    },
    { "id": 5, "title": "Refresh Token Reuse Detected", "type": "stat", "gridPos": { "h": 6, "w": 6, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "increase(auth_token_reuse_detected_total[1h])", "refId": "A" }]
    },
    { "id": 6, "title": "Outbox Pending", "type": "timeseries", "gridPos": { "h": 6, "w": 6, "x": 6, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "auth_outbox_lag_seconds", "refId": "A" }]
    },
    { "id": 7, "title": "Tokens Issued", "type": "timeseries", "gridPos": { "h": 6, "w": 6, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "sum(rate(auth_token_issued_total[5m])) by (type)", "legendFormat": "{{type}}", "refId": "A" }]
    },
    { "id": 8, "title": "Account-Service Circuit Breaker", "type": "timeseries", "gridPos": { "h": 6, "w": 6, "x": 18, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "auth_circuit_breaker_state", "refId": "A", "legendFormat": "cb {{target}}" }
      ]
    }
  ]
}
