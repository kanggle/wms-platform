{
  "uid": "jvm-dashboard",
  "title": "JVM Dashboard",
  "tags": ["jvm"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "query": "label_values(jvm_memory_used_bytes, job)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Heap Memory Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{job=\"$job\", area=\"heap\"}) by (id)",
          "legendFormat": "{{id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "stacking": { "mode": "normal" } },
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Heap Memory Max vs Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{job=\"$job\", area=\"heap\"})",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "sum(jvm_memory_max_bytes{job=\"$job\", area=\"heap\"})",
          "legendFormat": "Max",
          "refId": "B"
        },
        {
          "expr": "sum(jvm_memory_committed_bytes{job=\"$job\", area=\"heap\"})",
          "legendFormat": "Committed",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 },
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Non-Heap Memory Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{job=\"$job\", area=\"nonheap\"}) by (id)",
          "legendFormat": "{{id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "stacking": { "mode": "normal" } },
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "GC Pause Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{job=\"$job\"}[5m])",
          "legendFormat": "{{action}} {{cause}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 },
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "GC Count Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_count{job=\"$job\"}[5m])",
          "legendFormat": "{{action}} {{cause}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 },
          "unit": "ops"
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Live Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{job=\"$job\"}",
          "legendFormat": "Live",
          "refId": "A"
        },
        {
          "expr": "jvm_threads_daemon_threads{job=\"$job\"}",
          "legendFormat": "Daemon",
          "refId": "B"
        },
        {
          "expr": "jvm_threads_peak_threads{job=\"$job\"}",
          "legendFormat": "Peak",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 },
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "process_cpu_usage{job=\"$job\"}",
          "legendFormat": "Process CPU",
          "refId": "A"
        },
        {
          "expr": "system_cpu_usage{job=\"$job\"}",
          "legendFormat": "System CPU",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "title": "Loaded Classes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "jvm_classes_loaded_classes{job=\"$job\"}",
          "legendFormat": "Loaded",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 },
          "unit": "short"
        },
        "overrides": []
      }
    }
  ]
}
