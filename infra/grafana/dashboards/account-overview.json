{
  "uid": "account-overview",
  "title": "Account Service Overview",
  "tags": ["account"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    { "id": 1, "title": "Signup Rate", "type": "timeseries", "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "rate(account_signup_total[5m])", "refId": "A" }]
    },
    { "id": 2, "title": "Profile Reads", "type": "timeseries", "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "rate(account_profile_reads_total[5m])", "refId": "A" }]
    },
    { "id": 3, "title": "State Transitions", "type": "timeseries", "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "sum(rate(account_state_transition_total[5m])) by (from,to)", "legendFormat": "{{from}}->{{to}}", "refId": "A" }]
    },
    { "id": 4, "title": "Outbox Pending", "type": "timeseries", "gridPos": { "h": 6, "w": 8, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "account_outbox_lag_seconds", "refId": "A" }]
    },
    { "id": 5, "title": "DB Query Latency p99", "type": "timeseries", "gridPos": { "h": 6, "w": 8, "x": 8, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "histogram_quantile(0.99, sum(rate(hibernate_query_execution_seconds_bucket{service=\"account-service\"}[5m])) by (le))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    { "id": 6, "title": "4xx / 5xx Rate", "type": "timeseries", "gridPos": { "h": 6, "w": 8, "x": 16, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count{service=\"account-service\",status=~\"4..\"}[5m]))", "refId": "A", "legendFormat": "4xx" },
        { "expr": "sum(rate(http_server_requests_seconds_count{service=\"account-service\",status=~\"5..\"}[5m]))", "refId": "B", "legendFormat": "5xx" }
      ]
    },
    { "id": 7, "title": "Active Accounts (gauge)", "type": "stat", "gridPos": { "h": 6, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "account_active_count", "refId": "A" }]
    }
  ]
}
