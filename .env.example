# =============================================================================
# WMS Platform — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values as needed.
# Default values are set so that `docker compose up -d` works without .env.
# =============================================================================

# --- MySQL ---
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_PORT=3306

# --- MySQL Service User Passwords ---
INBOUND_DB_PASSWORD=inbound_pass
INVENTORY_DB_PASSWORD=inventory_pass
OUTBOUND_DB_PASSWORD=outbound_pass
MASTER_DB_PASSWORD=master_pass
ADMIN_DB_PASSWORD=admin_pass

# --- Redis ---
REDIS_PASSWORD=redispass
REDIS_PORT=6379

# --- Kafka (KRaft) ---
KAFKA_KRAFT_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qg
KAFKA_EXTERNAL_PORT=9093

# --- Kafka UI ---
KAFKA_UI_PORT=8090
