# =============================================================================
# WMS Platform — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values as needed.
# Defaults are tuned so `docker compose up -d` works without .env.
#
# ⚠️  Values with the `-changeme-local` suffix are local-dev-only placeholders.
#     Replace them with unique, strong values before any non-local deploy.
# =============================================================================

# --- Port namespace (monorepo convention — see TEMPLATE.md) ---
# Every docker-compose host port is prefixed with this single digit.
#   2 → 2XXXX (wms-platform 기본값, 예: Postgres 25432, Kafka 29093, Grafana 23000)
#   1 → 1XXXX (ecommerce 가 사용 중 — wms 단독 운영이면 충돌 없음)
#   3~6 → 향후 프로젝트용
# ecommerce 와 동시 기동하려면 이 값 그대로 둘 것.
PORT_PREFIX=2

# --- Postgres ---
POSTGRES_ROOT_PASSWORD=postgres-changeme-local

# Service-user passwords (one per wms service that owns state)
MASTER_DB_PASSWORD=master-changeme-local
INBOUND_DB_PASSWORD=inbound-changeme-local
INVENTORY_DB_PASSWORD=inventory-changeme-local
OUTBOUND_DB_PASSWORD=outbound-changeme-local
ADMIN_DB_PASSWORD=admin-changeme-local

# --- Kafka (KRaft) ---
KAFKA_KRAFT_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qg

# --- Observability ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin-changeme-local
