# =============================================================================
# WMS Platform — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values as needed.
# Defaults are tuned so `docker compose up -d` works without .env.
# =============================================================================

# --- Postgres ---
POSTGRES_ROOT_PASSWORD=postgres
POSTGRES_PORT=5432

# Service-user passwords (one per wms service that owns state)
MASTER_DB_PASSWORD=master
INBOUND_DB_PASSWORD=inbound
INVENTORY_DB_PASSWORD=inventory
OUTBOUND_DB_PASSWORD=outbound
ADMIN_DB_PASSWORD=admin

# --- Redis ---
REDIS_PORT=6379

# --- Kafka (KRaft) ---
KAFKA_KRAFT_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qg
KAFKA_EXTERNAL_PORT=9093
KAFKA_UI_PORT=8090

# --- Observability ---
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9095
LOKI_PORT=3100
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
